# CommerceJS Configuration
# ========================
# Copy this file to .env and fill in your values

# Database connection (Neon PostgreSQL recommended)
NUXT_COMMERCE_DATABASE_URL=postgresql://user:password@host/dbname

# Adapter — which backend platform to use
# Options: 'platform' (CommerceJS Platform), 'salla', 'medusa'
NUXT_COMMERCE_ADAPTER=platform

# Currency code (ISO 4217)
NUXT_COMMERCE_CURRENCY=SAR

# Google Maps API Key (optional — for delivery location picker)
GOOGLE_MAPS_KEY=

# --- Salla Adapter (if using adapter=salla) ---
# NUXT_COMMERCE_SALLA_TOKEN=
# NUXT_COMMERCE_SALLA_REFRESH_TOKEN=
# NUXT_COMMERCE_SALLA_CLIENT_ID=
# NUXT_COMMERCE_SALLA_SECRET=
# NUXT_COMMERCE_SALLA_LOCALE=ar
